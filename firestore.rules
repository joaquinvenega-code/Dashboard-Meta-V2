rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Security Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Securing Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Rules for Client collections
    match /clients/{clientId} {
      allow read: if isSignedIn();

      match /logs/{logId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidId(clientId) && isValidId(logId) 
          && incoming().text is string && incoming().text.size() <= 5000
          && incoming().date is string && incoming().date.size() <= 20;
        allow delete: if isSignedIn();
      }

      match /offline_sales/{saleId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidId(clientId) && isValidId(saleId)
          && incoming().amount is number && incoming().amount >= 0
          && incoming().date is string && incoming().date.size() <= 20;
        allow delete: if isSignedIn();
      }
    }
  }
}
